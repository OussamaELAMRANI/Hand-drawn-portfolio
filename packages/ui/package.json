{
  "name": "@larevo/ui",
  "version": "1.0.0",
  "description": "Shared Vue components",
  "private": true,
  "type": "module",
  "prettier": "@larevo/config/prettier",
  "exports": {
    ".": "./src/index.ts",
    "./components/*": "./src/components/*",
    "./features/*": "./src/features/*"
  },
  "imports": {
    "#components/*": "./src/components/*",
    "#composables/*": "./src/composables/*.ts",
    "#features/*": "./src/features/*",
    "#*": "./src/*"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "check-types": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@larevo/config": "workspace:^",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.10",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.6.0",
    "happy-dom": "^20.10.6",
    "typescript": "5.9.2",
    "vite": "^8.1.3",
    "vitest": "^4.1.10",
    "vue": "^3.5.39",
    "vue-tsc": "^3.3.6"
  },
  "dependencies": {
    "roughjs": "^4.6.6",
    "shiki": "^4.3.1"
  }
}
