{
  "name": "@larevo/ui",
  "version": "1.0.0",
  "description": "Shared Vue components",
  "private": true,
  "type": "module",
  "prettier": "@larevo/config/prettier",
  "exports": {
    ".": "./src/index.ts",
    "./components/*": "./src/components/*",
    "./features/*": "./src/features/*"
  },
  "imports": {
    "#components/*": "./src/components/*",
    "#composables/*": "./src/composables/*.ts",
    "#features/*": "./src/features/*",
    "#*": "./src/*"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "check-types": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@larevo/config": "workspace:^",
    "@vue/test-utils": "^2.4.11",
    "happy-dom": "^20.10.6",
    "vue": "^3.5.39"
  },
  "dependencies": {
    "@tiptap/core": "^3.27.4",
    "@tiptap/extension-highlight": "^3.27.4",
    "@tiptap/extensions": "^3.27.4",
    "@tiptap/pm": "^3.27.4",
    "@tiptap/starter-kit": "^3.27.4",
    "@tiptap/vue-3": "^3.27.4",
    "roughjs": "^4.6.6",
    "shiki": "^4.3.1"
  }
}
