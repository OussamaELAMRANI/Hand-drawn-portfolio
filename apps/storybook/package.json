{
  "name": "@larevo/storybook",
  "version": "1.0.0",
  "description": "Deployable Storybook for @larevo/ui components",
  "private": true,
  "type": "module",
  "prettier": "@larevo/config/prettier",
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "storybook build",
    "preview": "npx serve storybook-static",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check-types": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@larevo/ui": "workspace:^",
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@larevo/config": "workspace:^",
    "@storybook/vue3-vite": "^10.4.6",
    "@tailwindcss/vite": "^4.3.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "eslint": "^10.6.0",
    "storybook": "^10.4.6",
    "tailwindcss": "^4.3.2",
    "typescript": "5.9.2",
    "vite": "^8.1.3",
    "vue-tsc": "^3.3.6"
  }
}
